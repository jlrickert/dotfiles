# ---------------------------------------------------------------------------
# Layering contract (architectural; do not source across layers):
#
#   Layer 1 — POSIX env. THIS FILE (installed at ~/.config/dots/user/profile,
#             sourced via marker block in ~/.profile). Sourced by every login
#             shell, by zsh's .zshenv, and by non-interactive POSIX subshells.
#             MUST be POSIX sh. MUST be idempotent on FRONT-of-PATH for
#             prepends path_helper can demote; prepends are skipped only
#             when already at the front, so the re-source from ~/.zprofile
#             re-promotes them after path_helper.
#
#   Layer 2 — Per-package POSIX env fragments. ~/.config/dots/user/profile.d/*.sh
#             is sourced from the bottom of this file. Packages drop env
#             fragments here via their Dotfile.yaml `links:` entries.
#
#   Layer 3 — Per-shell interactive rc. bash/bashrc and zsh/zshrc own their
#             own interactive setup. NEVER source another shell's rc from
#             this layer or from Layer 2.
#
# Forbidden: a Layer-1 or Layer-2 file sourcing ~/.bashrc, ~/.zshrc, or any
# interactive rc. Doing so leaks bash-only completions into zsh and vice
# versa. Cross-shell exec (e.g. bash_profile -> zsh as login shell) is fine
# — that is policy, not sourcing.
# ---------------------------------------------------------------------------

# Shared POSIX login profile. Sourced by bash (via .bash_profile) and by
# any other POSIX shell started as a login shell. zsh does not source this
# directly -- zsh reads .zshenv/.zprofile instead.

# XDG base directory defaults.
: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_DATA_HOME:=$HOME/.local/share}"
: "${XDG_STATE_HOME:=$HOME/.local/state}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"
export XDG_CONFIG_HOME XDG_DATA_HOME XDG_STATE_HOME XDG_CACHE_HOME

# Locale.
: "${LANG:=en_US.UTF-8}"
export LANG

# Pager.
: "${PAGER:=less}"
export PAGER

# Identity / repo conventions.
: "${USER:=$(id -un 2>/dev/null || whoami)}"
: "${GITUSER:=$USER}"
: "${REPOS:=$HOME/repos}"
: "${GHREPOS:=$REPOS/github.com/$GITUSER}"
export USER GITUSER REPOS GHREPOS

# Make `cd <repo>` work from anywhere for repos under the GitHub user dir.
case ":${CDPATH:-}:" in
	*":$GHREPOS:"*) ;;
	*) CDPATH="${CDPATH:+$CDPATH:}$GHREPOS" ;;
esac
export CDPATH

# bat (modern cat) theme.
: "${BAT_THEME:=kanagawa_dragon}"
export BAT_THEME

# fzf defaults. The Debian/Ubuntu binary for fd is fdfind; on darwin/brew
# it's just fd. The repo installs both flavors via the install hook, so
# pick whichever is on PATH.
: "${FZF_DEFAULT_COMMAND:=rg --files --hidden --color=never}"
if command -v fdfind >/dev/null 2>&1; then
	: "${FZF_ALT_C_COMMAND:=fdfind --color=never --type d}"
elif command -v fd >/dev/null 2>&1; then
	: "${FZF_ALT_C_COMMAND:=fd --color=never --type d}"
fi
: "${FZF_ALT_C_OPTS:=--preview 'tree -C {}'}"
export FZF_DEFAULT_COMMAND FZF_ALT_C_COMMAND FZF_ALT_C_OPTS

# User-local bin directory.
case "$PATH" in
	"$HOME/.local/bin":*|"$HOME/.local/bin") ;;
	*) PATH="$HOME/.local/bin:$PATH" ;;
esac
export PATH

# Inlined `brew shellenv` equivalents. Avoids spawning brew (~50-80ms) on
# every shell init and skips brew's path_helper invocation, which would
# re-trigger the macOS login-shell PATH demotion fixed in commit af6c1ec.
# Resync if brew adds new env vars: run `<prefix>/bin/brew shellenv` and
# diff the output against this block. Apple Silicon is /opt/homebrew;
# Intel is /usr/local.
if [ -x /opt/homebrew/bin/brew ]; then
	HOMEBREW_PREFIX="/opt/homebrew"
	HOMEBREW_CELLAR="/opt/homebrew/Cellar"
	HOMEBREW_REPOSITORY="/opt/homebrew"
	export HOMEBREW_PREFIX HOMEBREW_CELLAR HOMEBREW_REPOSITORY
	case "$PATH" in
		/opt/homebrew/bin:*|/opt/homebrew/bin) ;;
		*) PATH="/opt/homebrew/bin:/opt/homebrew/sbin${PATH:+:$PATH}" ;;
	esac
	export PATH
	[ -z "${MANPATH-}" ] || export MANPATH=":${MANPATH#:}"
	export INFOPATH="/opt/homebrew/share/info${INFOPATH:+:$INFOPATH}"
elif [ -x /usr/local/bin/brew ]; then
	HOMEBREW_PREFIX="/usr/local"
	HOMEBREW_CELLAR="/usr/local/Cellar"
	HOMEBREW_REPOSITORY="/usr/local/Homebrew"
	export HOMEBREW_PREFIX HOMEBREW_CELLAR HOMEBREW_REPOSITORY
	case "$PATH" in
		/usr/local/bin:*|/usr/local/bin) ;;
		*) PATH="/usr/local/bin:/usr/local/sbin${PATH:+:$PATH}" ;;
	esac
	export PATH
	[ -z "${MANPATH-}" ] || export MANPATH=":${MANPATH#:}"
	export INFOPATH="/usr/local/share/info${INFOPATH:+:$INFOPATH}"
fi

# Default editor: prefer nvim, then vim, then nano. Force-assign rather
# than `:=` because nix-darwin's /etc/zshenv hard-exports EDITOR=nano
# before ~/.zshenv runs, and the "set if unset" idiom couldn't displace
# it. Per-machine overrides go in profile.d/ (see Layer 2 below).
for _ed in nvim vim nano; do
	if command -v "$_ed" >/dev/null 2>&1; then
		EDITOR="$_ed"
		VISUAL="$_ed"
		break
	fi
done
unset _ed
[ -n "${EDITOR:-}" ] && export EDITOR
[ -n "${VISUAL:-}" ] && export VISUAL

# Per-package env fragments (Layer 2). Packages drop *.sh files at
# ~/.config/dots/user/profile.d/ via their Dotfile.yaml links: entries.
# Must be POSIX-portable. Runs last so fragments can react to brew/bun
# PATH already being set. Fragments that want to override EDITOR/VISUAL
# must use plain assignment, not the `: "${VAR:=...}"` idiom, since the
# EDITOR block above already populated them.
_profile_d="${XDG_CONFIG_HOME:-$HOME/.config}/dots/user/profile.d"
if [ -d "$_profile_d" ]; then
	for _f in "$_profile_d"/*.sh; do
		[ -r "$_f" ] && . "$_f"
	done
fi
unset _profile_d _f
