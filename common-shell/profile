# Shared POSIX login profile. Sourced by bash (via .bash_profile) and by
# any other POSIX shell started as a login shell. zsh does not source this
# directly -- zsh reads .zshenv/.zprofile instead.

# XDG base directory defaults.
: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_DATA_HOME:=$HOME/.local/share}"
: "${XDG_STATE_HOME:=$HOME/.local/state}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"
export XDG_CONFIG_HOME XDG_DATA_HOME XDG_STATE_HOME XDG_CACHE_HOME

# Locale.
: "${LANG:=en_US.UTF-8}"
export LANG

# Pager.
: "${PAGER:=less}"
export PAGER

# Identity / repo conventions.
: "${USER:=$(id -un 2>/dev/null || whoami)}"
: "${GITUSER:=$USER}"
: "${REPOS:=$HOME/repos}"
: "${GHREPOS:=$REPOS/github.com/$GITUSER}"
export USER GITUSER REPOS GHREPOS

# Make `cd <repo>` work from anywhere for repos under the GitHub user dir.
case ":${CDPATH:-}:" in
	*":$GHREPOS:"*) ;;
	*) CDPATH="${CDPATH:+$CDPATH:}$GHREPOS" ;;
esac
export CDPATH

# bat (modern cat) theme.
: "${BAT_THEME:=gruvbox-dark}"
export BAT_THEME

# fzf defaults. The Debian/Ubuntu binary for fd is fdfind; on darwin/brew
# it's just fd. The repo installs both flavors via the install hook, so
# pick whichever is on PATH.
: "${FZF_DEFAULT_COMMAND:=rg --files --hidden --color=never}"
if command -v fdfind >/dev/null 2>&1; then
	: "${FZF_ALT_C_COMMAND:=fdfind --color=never --type d}"
elif command -v fd >/dev/null 2>&1; then
	: "${FZF_ALT_C_COMMAND:=fd --color=never --type d}"
fi
: "${FZF_ALT_C_OPTS:=--preview 'tree -C {}'}"
export FZF_DEFAULT_COMMAND FZF_ALT_C_COMMAND FZF_ALT_C_OPTS

# User-local bin directory.
case ":$PATH:" in
	*":$HOME/.local/bin:"*) ;;
	*) PATH="$HOME/.local/bin:$PATH" ;;
esac
export PATH

# Homebrew shellenv on macOS when present.
if [ -x /opt/homebrew/bin/brew ]; then
	eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
	eval "$(/usr/local/bin/brew shellenv)"
fi

# Bun runtime, when installed.
if [ -d "$HOME/.bun" ]; then
	export BUN_INSTALL="$HOME/.bun"
	case ":$PATH:" in
		*":$BUN_INSTALL/bin:"*) ;;
		*) PATH="$BUN_INSTALL/bin:$PATH" ;;
	esac
	export PATH
fi

# Default editor: prefer nvim, then vim, then nano. Pre-existing EDITOR /
# VISUAL win so per-machine overrides stay intact.
for _ed in nvim vim nano; do
	if command -v "$_ed" >/dev/null 2>&1; then
		: "${EDITOR:=$_ed}"
		: "${VISUAL:=$_ed}"
		break
	fi
done
unset _ed
[ -n "${EDITOR:-}" ] && export EDITOR
[ -n "${VISUAL:-}" ] && export VISUAL

# Per-package env fragments. Packages drop *.sh files here via their
# Dotfile.yaml links: entries. Must be POSIX-portable. Runs last so
# fragments can react to brew/bun PATH already being set. Fragments that
# want to override EDITOR/VISUAL must use plain assignment, not the
# `: "${VAR:=...}"` idiom, since the EDITOR block above already populated
# them.
_profile_d="${XDG_CONFIG_HOME:-$HOME/.config}/dots/profile.d"
if [ -d "$_profile_d" ]; then
	for _f in "$_profile_d"/*.sh; do
		[ -r "$_f" ] && . "$_f"
	done
fi
unset _profile_d _f
